# Contact-form email delivery (SMTP via Nodemailer).
# Copy to .env.local for local dev, and add the same vars in Vercel
# (Project → Settings → Environment Variables). Never commit real secrets.

# --- SMTP server (from your email provider) ---
# Gmail / Google Workspace:  smtp.gmail.com   (port 587)
# Microsoft 365 / Outlook:   smtp.office365.com (port 587)
SMTP_HOST=
SMTP_PORT=587
# Set to "true" only if you use port 465 (SSL). For 587 leave blank.
SMTP_SECURE=

# The mailbox login and an APP PASSWORD (not your normal password).
# Gmail app passwords: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=

# Where leads are delivered (defaults to jw@capitalwayne.com if unset).
CONTACT_TO=jw@capitalwayne.com
# The From address. Many providers require this to equal SMTP_USER.
CONTACT_FROM=
